@inject EditorState Editor
@inject VirtualFileSystem Vfs

<div class="relative overflow-hidden">
    <div class="hero-deko pointer-events-none absolute inset-0"></div>

    <div class="relative mx-auto max-w-5xl px-8 py-14">
        <div class="grid gap-10 lg:grid-cols-5 lg:items-center">

            <div class="lg:col-span-3">
                <h1 class="text-4xl font-bold leading-tight tracking-tight text-text sm:text-5xl">
                    Hallo, ich bin<br />Elias-Constantin Regber.
                </h1>

                <p class="mt-3 text-lg text-muted">
                    Full-Stack Developer · Teamleiter · Ausbilder
                    <span class="text-muted/70">· on-geo GmbH</span>
                </p>

                <div class="mt-6 space-y-3 text-[15px] leading-relaxed text-text/90">
                    <p>
                        Ich entwickle mit Schwerpunkt <strong class="font-semibold text-text">C# und .NET</strong>
                        und führe heute das Team, in dem ich meine eigene Ausbildung gemacht habe. Vom ersten
                        Commit zum Teamleiter und Ausbilder sind keine fünf Jahre vergangen.
                    </p>
                    <p>
                        Diese Seite ist bewusst als IDE gebaut: keine Marketing-Floskeln, sondern mein Profil so,
                        wie ich tatsächlich arbeite. Nimm dir einen Moment und folge dem roten Faden durch meine
                        Stationen.
                    </p>
                </div>

                <div class="mt-6 flex flex-wrap gap-2">
                    @foreach (var t in _stack)
                    {
                        <span class="rounded-md border border-border bg-surface px-2.5 py-1 text-xs font-medium text-text/80">
                            @t
                        </span>
                    }
                </div>

                <div class="mt-8 grid grid-cols-2 gap-3">
                    @foreach (var (label, wert) in _fakten)
                    {
                        <div class="rounded-md border border-border bg-surface px-4 py-3">
                            <div class="text-[11px] uppercase tracking-wide text-muted">@label</div>
                            <div class="mt-0.5 text-sm font-semibold text-text">@wert</div>
                        </div>
                    }
                </div>
            </div>

            <div class="order-first flex flex-col items-center gap-4 lg:order-last lg:col-span-2">
                <div class="relative aspect-square w-56 overflow-hidden rounded-full bg-surface
                            ring-2 ring-wood/40 shadow-cosy sm:w-64 lg:w-full lg:max-w-[18rem]">
                    <div class="grid h-full w-full place-items-center text-6xl font-bold text-wood">ER</div>
                    <img src="img/profil.jpg" alt="Elias-Constantin Regber" onerror="this.remove()"
                         class="absolute inset-0 h-full w-full object-cover" />
                </div>

                <span class="inline-flex items-center gap-2 rounded-full border border-border
                             bg-surface px-3 py-1 text-xs text-muted shadow-cosy">
                    <span class="relative flex h-2 w-2">
                        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-ok/70"></span>
                        <span class="relative inline-flex h-2 w-2 rounded-full bg-ok"></span>
                    </span>
                    Offen für fachlichen Austausch
                </span>
            </div>

        </div>

        <div class="mt-10 flex flex-wrap items-center gap-3">
            <button @onclick="TourStarten"
                    class="inline-flex items-center gap-2 rounded-md bg-wood px-5 py-2.5 text-sm
                           font-semibold text-white shadow-cosy transition hover:brightness-110">
                Geführte Tour starten
                <Icon Name="arrow-right" Class="h-3.5 w-3.5" />
            </button>
            <span class="text-sm text-muted">
                @Vfs.TourGesamt Stationen · ca. 3 Minuten
            </span>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-4 border-t border-border pt-6 text-sm">
            <span class="text-muted">Lieber direkt?</span>
            <a href="https://github.com/sirkyomi" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2 text-text/85 transition hover:text-wood">
                <Icon Name="github" Class="h-4 w-4" /> GitHub
            </a>
            <a href="https://www.linkedin.com/in/elias-constantin-regber-aa7513261/" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2 text-text/85 transition hover:text-wood">
                <Icon Name="linkedin-in" Class="h-4 w-4" /> LinkedIn
            </a>
            <span class="inline-flex items-center gap-2">
                <Icon Name="envelope" Class="h-4 w-4 text-muted" />
                <span class="font-mono text-xs text-text/85">@Email</span>
                <CopyButton Text="@Email" />
            </span>
        </div>
    </div>
</div>

@code {
    private const string Email = "mail@eliasregber.de";

    private readonly string[] _stack =
        ["C#", ".NET", "Blazor", "Angular", "React", "EF Core", "Azure DevOps", "Docker"];

    private readonly (string Label, string Wert)[] _fakten =
    [
        ("Rolle",       "Teamleiter & Ausbilder"),
        ("In der IT",   "seit 2021"),
        ("Team",        "5 Azubis · 2/Lehrjahr"),
        ("Kern-Stack",  "C# / .NET"),
    ];

    private void TourStarten()
    {
        var start = Vfs.Weiter(Vfs.Standarddatei);
        if (start is not null) Editor.Oeffnen(start);
    }
}
