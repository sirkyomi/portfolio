@inject VirtualFileSystem Vfs

<div class="mx-auto max-w-3xl px-6 py-10 sm:px-8">
    <ol class="relative border-l-2 border-border pl-8">
        @foreach (var s in Vfs.WerdegangDaten.Reverse())
        {
            <li class="relative mb-12 last:mb-0">
                                <span class="absolute -left-[41px] top-1 grid h-5 w-5 place-items-center rounded-full
                             border-2 @(s.Aktuell ? "border-wood bg-wood" : "border-border bg-bg")">
                    @if (s.Aktuell)
                    {
                        <span class="h-1.5 w-1.5 rounded-full bg-white"></span>
                    }
                </span>

                <div class="flex flex-wrap items-center gap-2">
                    <span class="font-mono text-xs text-wood">@Zeitraum(s)</span>
                    <span class="rounded-full border border-border px-2 py-0.5 text-[10px]
                                 uppercase tracking-wide text-muted">@TypLabel(s.Typ)</span>
                    @if (s.Aktuell)
                    {
                        <span class="rounded-full bg-wood/15 px-2 py-0.5 text-[10px]
                                     font-semibold uppercase tracking-wide text-wood">aktuell</span>
                    }
                </div>

                <h3 class="mt-1.5 text-2xl font-semibold tracking-tight text-text">@s.Titel</h3>
                <p class="text-sm text-muted">@s.Institution@(s.Ort is not null ? $" · {s.Ort}" : "")</p>

                @if (s.Highlight is not null)
                {
                    <p class="mt-2 border-l-2 border-wood/50 pl-3 text-sm font-medium text-wood">
                        @s.Highlight
                    </p>
                }

                @if (s.Beschreibung is not null)
                {
                    <p class="mt-3 max-w-2xl text-[15px] leading-relaxed text-text/80">@s.Beschreibung</p>
                }

                @if (s.Abschluss is { } a)
                {
                    <div class="mt-3 flex flex-wrap gap-2">
                        @if (a.IhkPunkte is { } p)
                        {
                            <span class="rounded-md bg-surface px-2.5 py-1 text-xs text-text/85">
                                IHK: @p / 100 Punkte
                            </span>
                        }
                        @if (a.Berufsschule is not null)
                        {
                            <span class="rounded-md bg-surface px-2.5 py-1 text-xs text-text/85">
                                Berufsschule: @a.Berufsschule
                            </span>
                        }
                        @if (a.Note is not null)
                        {
                            <span class="rounded-md bg-surface px-2.5 py-1 text-xs text-text/85">
                                Note: @a.Note
                            </span>
                        }
                    </div>
                }
            </li>
        }
    </ol>
</div>

@code {
    private static readonly string[] Monate =
        ["", "Jan.", "Feb.", "März", "Apr.", "Mai", "Juni", "Juli", "Aug.", "Sep.", "Okt.", "Nov.", "Dez."];

    private static string Zeitraum(WerdegangEintrag s) =>
        s.Bis is null ? $"seit {Datum(s.Von)}" : $"{Datum(s.Von)} bis {Datum(s.Bis)}";

    private static string Datum(string? iso)
    {
        if (string.IsNullOrEmpty(iso)) return "heute";
        var teile = iso.Split('-');
        return int.TryParse(teile.ElementAtOrDefault(1), out var m) && m is >= 1 and <= 12
            ? $"{Monate[m]} {teile[0]}"
            : iso;
    }

    private static string TypLabel(string typ) => typ switch
    {
        "schule" => "Schule",
        "ausbildung" => "Ausbildung",
        "beruf" => "Beruf",
        _ => typ,
    };
}
