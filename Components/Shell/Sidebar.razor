@implements IDisposable
@inject VirtualFileSystem Vfs
@inject UiState Ui

<aside class="@Klassen">
    <div class="flex-1 overflow-y-auto pb-2">
        <TourPanel />

        <div class="mt-3 border-t border-border pt-2">
            <div class="px-4 py-1.5 text-[11px] font-semibold uppercase tracking-wider text-muted">
                Explorer
            </div>
            <nav class="px-2">
                @foreach (var knoten in Vfs.Wurzel)
                {
                    <FileTreeNode Node="knoten" Tiefe="0" />
                }
            </nav>
        </div>
    </div>

    <ProfileLinks />
</aside>

@code {
    private string Klassen =>
        "fixed inset-y-0 left-0 z-40 flex w-72 flex-col border-r border-border bg-surface "
        + "transition-transform duration-200 lg:static lg:z-auto lg:w-64 lg:shrink-0 lg:translate-x-0 "
        + (Ui.SidebarOffen ? "translate-x-0 shadow-cosy" : "-translate-x-full");

    protected override void OnInitialized() => Ui.OnChange += Aktualisieren;
    private void Aktualisieren() => InvokeAsync(StateHasChanged);
    public void Dispose() => Ui.OnChange -= Aktualisieren;
}
