@inject UiState Ui

<header class="flex h-11 select-none items-center gap-3 border-b border-border bg-surface px-3 sm:px-4">
    <button @onclick="Ui.ToggleSidebar"
            aria-label="Menü öffnen"
            class="grid h-8 w-8 place-items-center rounded-lg text-muted transition
                   hover:bg-elevated hover:text-wood lg:hidden">
        <Icon Name="bars" Class="h-4 w-4" />
    </button>

    <div class="hidden items-center gap-2 sm:flex">
        <span class="h-3 w-3 rounded-full bg-[#e0654f]/90"></span>
        <span class="h-3 w-3 rounded-full bg-[#e0a93f]/90"></span>
        <span class="h-3 w-3 rounded-full bg-[#5fae6a]/90"></span>
    </div>

    <div class="flex-1 truncate text-center font-mono text-xs text-muted sm:text-sm">
        portfolio.sln · Elias-Constantin Regber
    </div>

    <ThemeToggle />
</header>
